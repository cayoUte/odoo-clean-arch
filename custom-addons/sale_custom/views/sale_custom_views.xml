<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- List view -->
  <record id="view_sale_custom_record_list" model="ir.ui.view">
    <field name="name">sale_custom.record.list</field>
    <field name="model">sale_custom.record</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <!-- Form view -->
  <record id="view_sale_custom_record_form" model="ir.ui.view">
    <field name="name">sale_custom.record.form</field>
    <field name="model">sale_custom.record</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <group>
            <field name="name"/>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <!-- Window action — bridges menu → view -->
<record id="action_sale_custom_record" model="ir.actions.act_window">
    <field name="name">Sale Custom Records</field>
    <field name="res_model">sale_custom.record</field>
    <field name="view_mode">list,form</field>
</record>
</odoo>

